// prisma/schema.postgres.prisma
// Postgres variant for the hosted build and for CI cross-engine coverage.
// Kept in sync with prisma/schema.prisma. Generation flow:
//   npx prisma generate --schema prisma/schema.postgres.prisma
//   npx prisma migrate dev --schema prisma/schema.postgres.prisma --name <name>
// Migrations live in prisma/migrations-postgres/ (separate from the sqlite set).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  rateLimit  Int?      @map("rate_limit")
  sessions   Session[]

  @@map("agents")
}

enum SessionStatus {
  open
  closed
}

model Session {
  id              String        @id
  agentId         String        @map("agent_id")
  agent           Agent         @relation(fields: [agentId], references: [id])

  // Artifact: the HTML/JS the agent wants rendered.
  artifactType    String        @map("artifact_type")
  artifactSource  String        @map("artifact_source")
  artifactVersion Int           @default(1) @map("artifact_version")

  // Schema: the per-session event vocabulary.
  eventSchema     Json          @map("event_schema")
  schemaVersion   Int           @default(1) @map("schema_version")

  status          SessionStatus @default(open)
  createdAt       DateTime      @default(now()) @map("created_at")
  expiresAt       DateTime      @map("expires_at")
  metadata        Json?

  // Webhook callback (best-effort, signed; durable delivery is /ee/).
  callbackUrl       String?     @map("callback_url")
  callbackSecretEnc String?     @map("callback_secret_enc")
  callbackFilter    Json?       @map("callback_filter")

  participants    Participant[]
  events          Event[]

  @@index([agentId])
  @@index([expiresAt])
  @@map("sessions")
}

model Participant {
  id           String    @id @default(cuid())
  sessionId    String    @map("session_id")
  session      Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  kind         String
  identityId   String    @map("identity_id")
  tokenHash    String    @unique @map("token_hash")
  tokenPrefix  String    @map("token_prefix")
  joinedAt     DateTime? @map("joined_at")
  revokedAt    DateTime? @map("revoked_at")

  @@index([sessionId])
  @@index([tokenHash])
  @@map("participants")
}

model Event {
  // Keep `Int` on both engines so the generated client surface is identical
  // (number, not bigint). Moving to @db.BigInt for the hosted Postgres build
  // is a separate migration once we're closer to capacity — tracked in the
  // project board.
  id              Int      @id @default(autoincrement())
  sessionId       String   @map("session_id")
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  authorKind      String   @map("author_kind")
  authorId        String   @map("author_id")
  type            String
  data            Json
  causationId     String?  @map("causation_id")
  idempotencyKey  String?  @map("idempotency_key")
  ts              DateTime @default(now())

  @@index([sessionId, id])
  @@unique([sessionId, authorId, idempotencyKey])
  @@map("events")
}
