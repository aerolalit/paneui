// prisma/schema.prisma
// provider = "sqlite" for the self-host/default build; "postgresql" for the hosted build (build-time switch).
// See docs/SPEC.md (Data model) and docs/architecture/phase-1-skeleton-and-data.md (Prisma schema section).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  rateLimit  Int?      @map("rate_limit")
  sessions   Session[]
  artifacts  Artifact[]

  @@map("agents")
}

// A reusable, versioned artifact owned by an agent. The head row carries the
// mutable identity (name, slug, description, tags); the per-version content
// lives in ArtifactVersion. An anonymous artifact (name/slug null) is created
// transparently for an inline one-off session.
model Artifact {
  id            String            @id @default(cuid())
  ownerId       String            @map("owner_id")
  owner         Agent             @relation(fields: [ownerId], references: [id])
  name          String?
  slug          String?
  description   String?
  tags          Json?
  latestVersion Int               @default(1) @map("latest_version")
  lastUsedAt    DateTime?         @map("last_used_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  versions      ArtifactVersion[]

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@map("artifacts")
}

// One immutable version of an artifact's content. Editing an artifact appends
// a new row; existing rows are never mutated. A session pins exactly one of
// these.
model ArtifactVersion {
  id             String    @id @default(cuid())
  artifactId     String    @map("artifact_id")
  artifact       Artifact  @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  version        Int
  artifactType   String    @map("artifact_type")
  artifactSource String    @map("artifact_source")
  eventSchema    Json      @map("event_schema")
  inputSchema    Json?     @map("input_schema")
  createdAt      DateTime  @default(now()) @map("created_at")
  sessions       Session[]

  @@unique([artifactId, version])
  @@index([artifactId])
  @@map("artifact_versions")
}

enum SessionStatus {
  open
  closed
}

model Session {
  id              String        @id
  agentId         String        @map("agent_id")
  agent           Agent         @relation(fields: [agentId], references: [id])

  // The pinned artifact version this session instantiates.
  artifactVersionId String          @map("artifact_version_id")
  artifactVersion   ArtifactVersion @relation(fields: [artifactVersionId], references: [id])

  // This instance's render data — validated against the version's input_schema.
  inputData         Json?         @map("input_data")

  status          SessionStatus @default(open)
  createdAt       DateTime      @default(now()) @map("created_at")
  expiresAt       DateTime      @map("expires_at")
  metadata        Json?

  // Webhook callback (best-effort, signed; durable delivery is /ee/).
  callbackUrl       String?     @map("callback_url")
  callbackSecretEnc String?     @map("callback_secret_enc")
  callbackFilter    Json?       @map("callback_filter")

  participants    Participant[]
  events          Event[]

  @@index([agentId])
  @@index([expiresAt])
  @@index([artifactVersionId])
  @@map("sessions")
}

model Participant {
  id           String    @id @default(cuid())
  sessionId    String    @map("session_id")
  session      Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  kind         String
  identityId   String    @map("identity_id")
  tokenHash    String    @unique @map("token_hash")
  tokenPrefix  String    @map("token_prefix")
  joinedAt     DateTime? @map("joined_at")
  revokedAt    DateTime? @map("revoked_at")

  @@index([sessionId])
  @@index([tokenHash])
  @@map("participants")
}

model Event {
  // SQLite quirk: only `INTEGER PRIMARY KEY` is a ROWID alias and auto-increments;
  // `BIGINT PRIMARY KEY` does not. SQLite stores up to 64 bits in any
  // integer-affinity column anyway, so declaring `Int` here is safe at the storage
  // layer. The wire cursor is opaque (a string), so we can override to `@db.BigInt`
  // on the Postgres build later without breaking clients.
  id              Int      @id @default(autoincrement())
  sessionId       String   @map("session_id")
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  authorKind      String   @map("author_kind")
  authorId        String   @map("author_id")
  type            String
  data            Json
  causationId     String?  @map("causation_id")
  idempotencyKey  String?  @map("idempotency_key")
  ts              DateTime @default(now())

  @@index([sessionId, id])
  @@unique([sessionId, authorId, idempotencyKey])
  @@map("events")
}
