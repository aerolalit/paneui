// prisma/schema.prisma
// provider = "sqlite" for the self-host/default build; "postgresql" for the hosted build (build-time switch).
// See docs/SPEC.md (Data model) and docs/architecture/phase-1-skeleton-and-data.md (Prisma schema section).
//
// Prisma 7 notes:
//   - The connection URL no longer lives here; the runtime creates a driver
//     adapter (better-sqlite3 / pg) from env and passes it to PrismaClient,
//     and the migrate CLI reads `prisma.config.ts` for the same URL. See
//     packages/relay/prisma.config.ts and packages/relay/src/db.ts.
//   - The legacy `prisma-client-js` generator is still accepted in 7 and
//     emits to node_modules/@prisma/client/ as before, so the relay's
//     `import { ... } from "@prisma/client"` import API stays unchanged.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Agent {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique @map("key_hash")
  keyPrefix  String    @map("key_prefix")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")
  rateLimit  Int?      @map("rate_limit")
  taste           String?   @map("taste")
  tasteUpdatedAt  DateTime? @map("taste_updated_at")

  // Optional human owner (claim flow). NULL = standalone agent (today's
  // model — CI bots, scratch scripts). Non-null = claimed by this human;
  // panes and templates created by this agent flow into that human's
  // "my-*" catalogs (see Human-side proposal §6).
  ownerHumanId    String?   @map("owner_human_id")
  ownerHuman      Human?    @relation(fields: [ownerHumanId], references: [id], onDelete: SetNull)
  claimedAt       DateTime? @map("claimed_at")

  panes    Pane[]
  templates   Template[]
  feedback    Feedback[]
  attachments Attachment[]
  // Back-relation from Participant.agent (Phase A polymorphic participants).
  // Named relation avoids the collision with Agent <- Pane.agentId above.
  participantOf Participant[] @relation("ParticipantAgent")

  // #302 — soft-delete timestamp. NULL = active. Set by hard-delete on demand
  // (`DELETE ?permanent=true`) is the only path that skips this; normal delete
  // sets `deletedAt` and the hard-delete sweeper (#304) reclaims rows whose
  // retention window has elapsed. Distinct from `revokedAt` which is the
  // agent-key revocation state; the two coexist (an agent can be revoked but
  // not soft-deleted, or vice versa).
  deletedAt  DateTime? @map("deleted_at")

  @@index([ownerHumanId])
  @@index([deletedAt])
  @@map("agents")
}

// A first-class human identity. Created by:
//   - First magic-link login (manual signup): row created, verifiedAt set.
//   - Email invite (Alice invites bob@…): row created with verifiedAt NULL;
//     verifiedAt set on bob's first successful login.
model Human {
  id             String    @id @default(cuid())
  email          String    @unique
  // Non-null once first magic-link login succeeds (proof the human controls
  // the email). Until then the row exists but the email isn't proven.
  verifiedAt     DateTime? @map("verified_at")
  phone          String?
  // The human's pinned home template — overridable in settings. NULL means
  // serve the pane-default `home` template. See §5.2 bootstrap.
  homeTemplateId String?   @map("home_template_id")
  homeTemplate   Template? @relation("HumanHomeTemplate", fields: [homeTemplateId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now()) @map("created_at")

  logins         Login[]
  claimedAgents  Agent[]
  templateInstalls HumanTemplateInstall[]
  claimCodes     ClaimCode[]
  // Panes owned by this human (Phase A — Pane.ownerHumanId)
  ownedPanes  Pane[]
  // Participations where this human is identity-bound on a pane
  participantOf  Participant[]

  // #302 — soft-delete + retention policy.
  //
  // `deletedAt`: NULL = active. A soft-deleted human cascades to their claimed
  // agents (Phase 1 hard-delete sweeper handles the cascade — see #304).
  //
  // `tier`: gates retention. 'free' uses HARD_RETENTION_DAYS_FREE (default
  // 30 days); 'paid' uses HARD_RETENTION_DAYS_PAID (default null = never
  // hard-delete); 'system' is for the relay-internal humans (e.g. the
  // home-template owner) and is NEVER hard-deleted.
  //
  // `softRetentionDays` / `hardRetentionDays`: per-human override. NULL
  // means "use the tier default." Useful for ad-hoc extended retention
  // (e.g. compliance hold) or shorter retention for a clearly-throwaway
  // account.
  deletedAt         DateTime? @map("deleted_at")
  tier              String    @default("free") // 'free' | 'paid' | 'system'
  softRetentionDays Int?      @map("soft_retention_days")
  hardRetentionDays Int?      @map("hard_retention_days")

  @@index([email])
  @@index([deletedAt])
  @@map("humans")
}

// One logged-in state for one human. Backs an HTTP-only cookie on the
// relay's bridge origin. Distinct from "Pane" (the data row formerly
// called "Session" in pane), hence the name `Login` not `Session`.
model Login {
  id          String    @id @default(cuid())
  humanId     String    @map("human_id")
  human       Human     @relation(fields: [humanId], references: [id], onDelete: Cascade)
  // sha256(token) — never store the raw cookie value.
  cookieHash  String    @unique @map("cookie_hash")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastSeenAt  DateTime? @map("last_seen_at")

  @@index([humanId])
  @@index([expiresAt])
  @@map("logins")
}

// One-shot, short-TTL code Alice generates in Settings → "Claim an agent".
// Alice copies it out-of-band to her agent; the agent calls
// POST /v1/agents/claim with the code to bind itself to Alice (§6.1).
model ClaimCode {
  id          String    @id @default(cuid())
  humanId     String    @map("human_id")
  human       Human     @relation(fields: [humanId], references: [id], onDelete: Cascade)
  // sha256(code) — the code is shown to the human once at generate-time
  // and never stored. The agent submits the raw code; the relay hashes
  // and looks it up.
  codeHash    String    @unique @map("code_hash")
  expiresAt   DateTime  @map("expires_at")
  // Set when the code is redeemed; the code is then invalid for further use.
  consumedAt  DateTime? @map("consumed_at")
  // Bookkeeping: which agent ultimately consumed it.
  consumedByAgentId String? @map("consumed_by_agent_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([humanId])
  @@index([expiresAt])
  @@map("claim_codes")
}

// A magic-link email sent to (potentially) prove ownership of an email
// address. The token in the link is hashed and stored here; on click the
// relay validates + consumes the row and either creates the matching
// Human (if not already present) or attaches the new Login to the
// existing one. Bound to email, not humanId — the Human row may not
// exist yet when the link is requested (signup-via-invite is implicit).
model MagicLink {
  id          String    @id @default(cuid())
  // The email the link was sent to. The eventual Login is attached to
  // the Human row matching this email (find-or-create at consume time).
  email       String
  // sha256(token) — the raw token is in the email link and never stored.
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  // Set when the token is redeemed. Once-only by construction.
  consumedAt  DateTime? @map("consumed_at")
  // Optional return URL captured at /login. The relay redirects here on
  // successful verify so "log in to see this pane" deep links work.
  returnUrl   String?   @map("return_url")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("magic_links")
}

// Alice installs a public template into her catalog. Pins to the version
// in effect at install time so a later publish doesn't silently change
// behaviour or scopes (re-consent flow only fires on explicit upgrade).
model HumanTemplateInstall {
  id               String    @id @default(cuid())
  humanId          String    @map("human_id")
  human            Human     @relation(fields: [humanId], references: [id], onDelete: Cascade)
  templateId       String    @map("template_id")
  template         Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  installedVersion Int       @map("installed_version")
  installedAt      DateTime  @default(now()) @map("installed_at")
  uninstalledAt    DateTime? @map("uninstalled_at")

  // #267 PR C — upgrade policy for new TemplateVersions published by the
  // author after install.
  //   "pin"     (default): stay on installedVersion until the human
  //             explicitly upgrades via POST /v1/templates/:id/upgrade.
  //   "follow": auto-advance to the new version when the author publishes,
  //             gated by the same schema-compat check the pane-upgrade
  //             route uses. An advance blocked by incompat sets
  //             upgrade_blocked_at + upgrade_blocked_reason; the human
  //             sees a yellow pill on /my-templates and can resolve
  //             manually (force-upgrade or wait for a wider version).
  upgradePolicy        String    @default("pin") @map("upgrade_policy")
  upgradeBlockedAt     DateTime? @map("upgrade_blocked_at")
  upgradeBlockedReason Json?     @map("upgrade_blocked_reason")

  @@unique([humanId, templateId])
  @@index([humanId])
  @@index([templateId])
  @@map("human_template_installs")
}

model Feedback {
  id             String   @id @default(cuid())
  agentId        String?  @map("agent_id")
  type           String
  message        String
  paneId      String?  @map("pane_id")
  githubIssueUrl String?  @map("github_issue_url")
  createdAt      DateTime @default(now()) @map("created_at")

  agent   Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  pane Pane? @relation(fields: [paneId], references: [id], onDelete: SetNull)

  @@index([agentId, createdAt])
  @@index([createdAt])
  @@map("feedback")
}

// A reusable, versioned template owned by an agent. The head row carries the
// mutable identity (name, slug, description, tags); the per-version content
// lives in TemplateVersion. An anonymous template (name/slug null) is created
// transparently for an inline one-off pane.
model Template {
  id            String            @id @default(cuid())
  ownerId       String            @map("owner_id")
  owner         Agent             @relation(fields: [ownerId], references: [id])
  name          String?
  slug          String?
  description   String?
  tags          Json?
  latestVersion Int               @default(1) @map("latest_version")
  lastUsedAt    DateTime?         @map("last_used_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  versions      TemplateVersion[]

  // "view" | "interactive". `view` templates have no event vocabulary and
  // their panes skip event-log persistence (rendered against live relay
  // state via the runtime API). `interactive` is today's default — events
  // and event log fully apply. See Human-side proposal §3.2.
  shape         String            @default("interactive")

  // Publication state. NULL = unpublished (default; templates are private
  // until explicit publish). Non-null = published to the public catalog.
  publishedAt   DateTime?         @map("published_at")
  // Declared scopes the template needs at install time (JSON array of
  // strings). Frozen per version; a new version reopens scope consent.
  scopes        Json?
  // Denormalised count of HumanTemplateInstall rows pointing here. Updated
  // on install/uninstall. Lets the public catalog rank/sort cheaply.
  installCount  Int               @default(0) @map("install_count")

  attachments   Attachment[]
  installs      HumanTemplateInstall[]
  humanHomes    Human[]           @relation("HumanHomeTemplate")

  // Template-level mutable record collections (shared across every pane
  // derived from any version of this template). Owner-curated; pages read
  // through the in-iframe template-records bridge. Schema declaration lives
  // on TemplateVersion.templateRecordSchema so it can evolve through version
  // bumps under the schema-compat gate.
  templateRecordCollections TemplateRecordCollection[]

  // #302 — soft-delete timestamp. NULL = active. See Agent.deletedAt for
  // semantics; templates follow the same model.
  deletedAt     DateTime?         @map("deleted_at")

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("templates")
}

// One immutable version of a template's content. Editing a template appends
// a new row; existing rows are never mutated. A pane pins exactly one of
// these.
model TemplateVersion {
  id             String    @id @default(cuid())
  templateId     String    @map("template_id")
  template       Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version        Int
  templateType   String    @map("template_type")
  templateSource String    @map("template_source")
  eventSchema    Json?     @map("event_schema")
  inputSchema    Json?     @map("input_schema")
  // #288 — JSON Schema 2020-12 document declaring the template's record
  // collections (under `x-pane-collections`). NULL = template has no
  // record collections (the default; record support is opt-in per template).
  // Schema-only column for now; validation, writers, and routes ship in
  // follow-up issues (#289 / #291 / #292).
  recordSchema   Json?     @map("record_schema")
  // Template-level record collections declared on this version (parallel to
  // recordSchema but for the Template-scoped store). Same shape: a JSON
  // Schema 2020-12 document with an `x-pane-collections` extension. NULL =
  // version declares no template-level collections. Persisted per-version
  // so the publisher can evolve the schema through version bumps; the
  // schema-compat gate (#267) ensures backwards-compatible upgrades.
  templateRecordSchema Json? @map("template_record_schema")
  createdAt      DateTime  @default(now()) @map("created_at")
  panes       Pane[]
  // Back-relation for Event.templateVersion (#268). Stamping the pane's
  // pinned templateVersionId on each event at write-time lets a future
  // upgrade (#267) read old events under the new schema (Level 1
  // polymorphic render).
  events         Event[]

  @@unique([templateId, version])
  @@index([templateId])
  @@map("template_versions")
}

enum PaneStatus {
  open
  closed
}

model Pane {
  id              String        @id
  agentId         String        @map("agent_id")
  agent           Agent         @relation(fields: [agentId], references: [id])

  // Phase A additions — human-side ownership. NULL = today's behavior
  // (agent-owned via agentId). Non-null = human-owned (claimed agent's
  // pane, or human-instantiated via a template). Eventually
  // (Phase D) agentId becomes redundant and the agent moves to being
  // just a Participant, but for now both columns coexist.
  ownerHumanId    String?       @map("owner_human_id")
  ownerHuman      Human?        @relation(fields: [ownerHumanId], references: [id], onDelete: SetNull)
  // The natural key for "same logical thing" — `"home"`, `"pr:42"`, etc.
  // NULL = ad-hoc pane, no dedup. Used by pane-create to dedupe
  // (template, owner, contextKey) into a single row.
  contextKey      String?       @map("context_key")
  // Audit-only — who actually instantiated the pane. Not load-bearing
  // (privilege flows from owner + participants).
  creatorKind     String?       @map("creator_kind")
  creatorId       String?       @map("creator_id")
  // Per-pane invitation policy override (see Human-side proposal §7.2).
  // JSON shape: { humansCanInviteHumans: bool, humansCanInviteAgents: bool }.
  // NULL = permissive Google-Docs default.
  invitePolicy    Json?         @map("invite_policy")

  // The pinned template version this pane instantiates.
  templateVersionId String          @map("template_version_id")
  templateVersion   TemplateVersion @relation(fields: [templateVersionId], references: [id])

  // This instance's render data — validated against the version's input_schema.
  inputData         Json?         @map("input_data")

  // Per-pane tab title shown in the browser's <title>. Required for every
  // pane; supplied by the agent (or resolved server-side from the named
  // template's `name`). Trust boundary: untrusted agent input — rendered
  // (HTML-escaped) into the bridge shell's <title>.
  title           String

  // Optional one-line/two-line context message the agent supplies at create
  // time. Rendered (HTML-escaped) in the shell band above the iframe so the
  // human sees "who is asking, why" before reading the artifact. Trust
  // boundary: untrusted agent input; escaped at render. Max 280 chars; one
  // `\n` permitted, other control chars rejected at the route.
  preamble        String?
  status          PaneStatus @default(open)
  createdAt       DateTime      @default(now()) @map("created_at")
  expiresAt       DateTime      @map("expires_at")
  metadata        Json?

  // Webhook callback (best-effort, signed; durable delivery is /ee/).
  callbackUrl       String?     @map("callback_url")
  callbackSecretEnc String?     @map("callback_secret_enc")
  callbackFilter    Json?       @map("callback_filter")

  participants    Participant[]
  events          Event[]
  feedback        Feedback[]
  attachments     Attachment[]
  // #288 — per-pane mutable record collections.
  recordCollections RecordCollection[]

  // #302 — soft-delete timestamp. NULL = active. When the TTL sweeper
  // (#303) fires it sets `deletedAt = now()` instead of `DELETE`-ing the
  // row, so the pane (and its events, participants, attachments) stays
  // recoverable for the configured trash window. The hard-delete sweeper
  // (#304) reclaims rows past the retention window. Distinct from
  // `status = "closed"`: closed panes don't accept new events but stay
  // listable; soft-deleted panes are filtered from default queries.
  deletedAt       DateTime?     @map("deleted_at")

  @@index([agentId])
  @@index([expiresAt])
  @@index([templateVersionId])
  @@index([ownerHumanId])
  @@index([deletedAt])
  // Dedup index — (templateVersionId, ownerHumanId, contextKey) is unique
  // for human-owned panes with a contextKey. Panes without a
  // contextKey are not deduped (ad-hoc).
  @@unique([templateVersionId, ownerHumanId, contextKey])
  @@map("panes")
}

model Participant {
  id           String    @id @default(cuid())
  paneId    String    @map("pane_id")
  pane      Pane   @relation(fields: [paneId], references: [id], onDelete: Cascade)
  // "human" | "agent". Polymorphic FKs:
  //   kind = 'human' AND humanId NULL  → anonymous capability human (legacy + share-link)
  //   kind = 'human' AND humanId set   → identity-bound human (email invite)
  //   kind = 'agent' AND agentId set   → agent participant
  kind         String
  identityId   String    @map("identity_id")
  // Phase A polymorphic FKs — exactly one of humanId/agentId is set when
  // the participant is identity-bound; both NULL is allowed only for
  // kind='human' (anonymous capability participants).
  humanId      String?   @map("human_id")
  human        Human?    @relation(fields: [humanId], references: [id], onDelete: SetNull)
  agentId      String?   @map("agent_id")
  agent        Agent?    @relation("ParticipantAgent", fields: [agentId], references: [id], onDelete: SetNull)
  tokenHash    String    @unique @map("token_hash")
  tokenPrefix  String    @map("token_prefix")
  joinedAt     DateTime? @map("joined_at")
  revokedAt    DateTime? @map("revoked_at")

  // The (paneId, identityId) pair must be unique even across revoked
  // rows. The mint route derives identityId monotonically from the
  // ever-minted human count (#206 / #201), but two concurrent POSTs to
  // `/v1/panes/:id/participants` can both read the same count and
  // both attempt `h_${N}`. The constraint serialises the write at the
  // DB layer (P2002 on the loser); the route catches the error and
  // retries against the new count. Without the constraint, the race
  // panes as silently aliased identityIds — the WS handler's
  // `findFirst({ where: { paneId, identityId } })` would then
  // non-deterministically resolve events to whichever row sorted first.
  // See #215.
  @@unique([paneId, identityId])
  @@index([paneId])
  @@index([tokenHash])
  @@map("participants")
}

model Event {
  // SQLite quirk: only `INTEGER PRIMARY KEY` is a ROWID alias and auto-increments;
  // `BIGINT PRIMARY KEY` does not. SQLite stores up to 64 bits in any
  // integer-affinity column anyway, so declaring `Int` here is safe at the storage
  // layer. The wire cursor is opaque (a string), so we can override to `@db.BigInt`
  // on the Postgres build later without breaking clients.
  id              Int      @id @default(autoincrement())
  paneId       String   @map("pane_id")
  pane         Pane  @relation(fields: [paneId], references: [id], onDelete: Cascade)
  authorKind      String   @map("author_kind")
  authorId        String   @map("author_id")
  type            String
  data            Json
  causationId     String?  @map("causation_id")
  idempotencyKey  String?  @map("idempotency_key")
  ts              DateTime @default(now())

  // #268 — stamp the pane's pinned template_version at write time so a
  // downstream upgrade (#267) can read old events under the new schema. Both
  // fields are nullable to handle two cases: events written before this
  // column existed (the migration backfills them, but tolerate a
  // SET NULL on cascade so a TemplateVersion delete doesn't cascade-
  // delete the historical event log), and the brief race-window in which a
  // system event is written before the pane's templateVersion can be
  // loaded (logged + treated as best-effort, see appendSystemEvent).
  //
  // `templateVersionNum` is the denormalised integer version number
  // (TemplateVersion.version) — kept on the row so the read path doesn't
  // need a join. Immutable per templateVersionId (version numbers are
  // assigned once at TemplateVersion create and never edited), so the
  // denormalisation is safe.
  templateVersionId  String?           @map("template_version_id")
  templateVersion    TemplateVersion?  @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  templateVersionNum Int?              @map("template_version_num")

  @@index([paneId, id])
  @@unique([paneId, authorId, idempotencyKey])
  @@map("events")
}


// #288 — A per-pane, named mutable record collection. There is no row
// for a collection until the first PaneRecord is written into it
// (collections are created implicitly on first write). The `(paneId, name)`
// pair is the natural key clients use.
//
// `seq` is the per-collection monotonic write cursor, bumped on every upsert
// or soft-delete. Clients reconnecting via `?since=<seq>` fetch deltas with
// a single `WHERE collection_id = ? AND seq > ?` select against
// PaneRecord. See the epic in issue #287 for the full design.
model RecordCollection {
  id          String          @id @default(cuid())
  paneId   String          @map("pane_id")
  pane     Pane         @relation(fields: [paneId], references: [id], onDelete: Cascade)
  name        String
  seq         Int             @default(0)
  records     PaneRecord[]

  @@unique([paneId, name])
  @@map("record_collections")
}

// #288 — One row per record in a collection. `recordKey` is the stable
// client-facing identifier for the row across edits (client-supplied OR
// server-generated `rec_<cuid>`). `version` is the optimistic-locking
// counter (clients pass `If-Match: <version>`; mismatch → 409). `seq` is
// the snapshot of RecordCollection.seq taken at write time so a single
// select can return the delta page for reconnect resume.
//
// Soft delete is load-bearing: a `DELETE` bumps `seq` and sets `deletedAt`
// so clients reconnecting after the delete still observe the tombstone.
// Hard cleanup runs out of a background sweeper after RECORD_TOMBSTONE_TTL
// (separate issue).
model PaneRecord {
  id           String           @id @default(cuid())
  collectionId String           @map("collection_id")
  collection   RecordCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  recordKey    String           @map("record_key")
  data         Json
  version      Int              @default(1)
  seq          Int
  // "agent" | "human" — mirrors Event.authorKind.
  authorKind   String           @map("author_kind")
  authorId     String           @map("author_id")
  deletedAt    DateTime?        @map("deleted_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@unique([collectionId, recordKey])
  @@index([collectionId, seq])
  @@map("pane_records")
}

// Template-level record collections (shared content scoped to a Template
// head, visible to every pane derived from any version of the template).
// Peer to RecordCollection, but anchored at the Template head rather than
// a Pane — so a publisher can curate a list of questions / featured links /
// shared options once and have it appear in every derived pane.
//
// Created implicitly on first write into the collection. `seq` is the
// per-collection monotonic write cursor, bumped on every upsert or
// soft-delete (mirrors RecordCollection.seq exactly).
model TemplateRecordCollection {
  id         String           @id @default(cuid())
  templateId String           @map("template_id")
  template   Template         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  seq        Int              @default(0)
  records    TemplateRecord[]

  @@unique([templateId, name])
  @@map("template_record_collections")
}

// One row per record in a template-level collection. Column-for-column
// parallel to PaneRecord; same optimistic-locking semantics, same soft-
// delete + tombstone-sweeper lifecycle. Authorship is always the owner
// human (kind = "human") or one of the owner's claimed agents
// (kind = "agent"); writes by non-owners are rejected at the route layer.
model TemplateRecord {
  id           String                   @id @default(cuid())
  collectionId String                   @map("collection_id")
  collection   TemplateRecordCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  recordKey    String                   @map("record_key")
  data         Json
  version      Int                      @default(1)
  seq          Int
  // "agent" | "human" — mirrors PaneRecord.authorKind exactly.
  authorKind   String                   @map("author_kind")
  authorId     String                   @map("author_id")
  deletedAt    DateTime?                @map("deleted_at")
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")

  @@unique([collectionId, recordKey])
  @@index([collectionId, seq])
  @@map("template_records")
}

// A binary attachment scoped to a template, a pane, or an agent's reusable
// asset library. The bytes themselves live in the configured AttachmentStore
// (filesystem self-host or Azure Attachment hosted); this row is the metadata,
// authz anchor, and lifecycle hook.
//
// Scopes:
//   - "agent"    — reusable across the agent's panes. templateId + paneId
//                  both null. Lives until explicit delete or LRU eviction.
//   - "pane"  — bound to one pane. paneId set, templateId null. Dies
//                  with the pane (cascade).
//   - "template" — bound to one reusable template (the head, not a specific
//                  version). templateId set, paneId null. Dies with the
//                  template.
//
// Exactly one of (templateId set, paneId set, neither set) is true; the
// scope column is the source of truth and the application layer enforces this.
// Cross-tenant access is denied at the route layer — ownerId is the authz
// anchor, never the storageKey or the FK columns.
model Attachment {
  id            String    @id @default(cuid())

  // Ownership. Pane has no human-identity concept yet, so the agent IS the
  // owner. Participant uploads are credited to the pane's owning agent
  // (the participant token authorises the action, not ownership).
  ownerId       String    @map("owner_id")
  owner         Agent     @relation(fields: [ownerId], references: [id])

  // Scope: "agent" | "pane" | "template". See model-level comment.
  scope         String

  // Set when scope = "pane". Cascades on pane delete/expire.
  paneId     String?   @map("pane_id")
  pane       Pane?  @relation(fields: [paneId], references: [id], onDelete: Cascade)

  // Set when scope = "template". Cascades on template delete.
  templateId    String?   @map("template_id")
  template      Template? @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Content metadata. mime comes from server-side magic-byte sniff, NOT the
  // client's Content-Type. sha256 is hex-encoded; size is bytes (capped at
  // MAX_ATTACHMENT_BYTES at upload time, well within Int range for v0.1.0's 5 MB).
  mime          String
  size          Int
  sha256        String
  width         Int?
  height        Int?

  // Opaque key inside the AttachmentStore. Never user-supplied; never used as
  // a filesystem path component directly. Storage backends derive their own
  // path from this id (e.g. filesystem uses `<root>/att_<id>`, Azure uses
  // `att_<id>` as the attachment name).
  storageKey    String    @unique @map("storage_key")

  // Lifecycle status:
  //   "pending"   — upload presigned but not confirmed
  //   "ready"     — confirmed + HEAD-verified + scanned (if scan hook on)
  //   "failed"    — upload or scan failed; metadata kept for audit
  //   "deleted"   — soft-deleted; bytes already removed from AttachmentStore
  status        String    @default("pending")

  // Optional human-supplied display name (for UX). Never a path component.
  filename      String?

  // EXIF + thumbnail strip toggle. Default true; agents can opt out per-attachment
  // for legit photo-management use cases where DateTimeOriginal matters.
  stripMetadata Boolean   @default(true) @map("strip_metadata")

  // Envelope encryption-at-rest. NULL when the relay's ATTACHMENT_ENCRYPT_AT_REST
  // is off (the default). When set, the bytes in the AttachmentStore are
  // ciphertext; this column carries the wrapped DEK + data IV + data tag
  // needed to decrypt them. Stored as a base64 JSON envelope so future
  // versions (e.g. customer-managed keys, key rotation) can extend the
  // shape without another migration.
  encryptionEnvelope String? @map("encryption_envelope")

  createdAt     DateTime  @default(now()) @map("created_at")
  confirmedAt   DateTime? @map("confirmed_at")
  deletedAt     DateTime? @map("deleted_at")

  @@index([ownerId])
  @@index([scope, ownerId])
  @@index([paneId])
  @@index([templateId])
  @@map("attachments")

  tokens AttachmentToken[]
}

// Capability URL for an attachment. Each row mints one /a/<token> link that
// any holder can use to fetch the bytes without an agent API key — this is
// the participant-facing download path.
//
// A token's lifetime is bound to its attachment's scope (see proposal #152):
//
//   - template-scope: token TTL = ATTACHMENT_TOKEN_TTL_TEMPLATE_SECONDS (30d default)
//   - pane-scope:  token TTL = the pane's TTL (cascades on pane delete)
//   - agent-scope:    token TTL = ATTACHMENT_TOKEN_TTL_AGENT_SECONDS (24h default)
//
// `once = true` deletes the token on its first successful GET — for the
// "share a private doc, expire after view" pattern.
//
// Audit columns persist enough provenance to spot an exfiltrated token
// without storing exact requester IPs: `first_seen_ip_net` / `last_seen_ip_net`
// are /24-truncated IPv4 (or /48-truncated IPv6) ranges. Truncation happens
// at write time — full IPs are never persisted.
model AttachmentToken {
  id          String    @id @default(cuid())
  attachmentId String   @map("attachment_id")
  attachment  Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  // sha256 hex of the token string. The token itself is never stored — only
  // its hash, mirroring how Agent keys and Participant tokens are stored.
  tokenHash   String    @unique @map("token_hash")
  // First 10 chars of the token, kept for log + UX so an operator can match
  // a redacted access log entry to its row.
  tokenPrefix String    @map("token_prefix")

  // Lifetime + use semantics.
  expiresAt   DateTime  @map("expires_at")
  once        Boolean   @default(false)
  revokedAt   DateTime? @map("revoked_at")

  // Audit. useCount, lastUsedAt, and the truncated IP ranges are updated on
  // every successful GET; the relay never persists a full requester IP.
  useCount       Int       @default(0) @map("use_count")
  lastUsedAt     DateTime? @map("last_used_at")
  firstSeenIpNet String?   @map("first_seen_ip_net")
  lastSeenIpNet  String?   @map("last_seen_ip_net")

  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([attachmentId])
  @@index([expiresAt])
  @@map("attachment_tokens")
}

// #302 — append-only audit trail for the soft-delete / restore / hard-delete
// lifecycle. One row per state transition on any soft-deletable entity
// (Pane, Template, Agent, Human, Attachment). Used by:
//   - The Trash UI (#309) to list "what was deleted, by whom, when, why"
//   - The hard-delete sweeper (#304) which appends a row on every reclaim
//   - The restore endpoint (#306) which appends a row when undeleting
//
// No FK to the entity — the row outlives the entity (hard-delete removes
// the entity but keeps the audit row indefinitely). `entityId` is opaque.
// Denormalised owner ids make the by-human trash query (#306 /v1/trash)
// a single index scan.
model DeletionLog {
  id           String    @id @default(cuid())
  // 'pane' | 'template' | 'human' | 'agent' | 'attachment'
  entityType   String    @map("entity_type")
  // The deleted entity's cuid. Not a FK — the entity may be hard-deleted
  // later and this row outlives it.
  entityId     String    @map("entity_id")
  // Owner anchors for the trash-by-human query. Both nullable: agent-only
  // resources (a standalone agent's panes before it's claimed) have no
  // human owner; conversely human-only resources have no owning agent.
  ownerHumanId String?   @map("owner_human_id")
  ownerAgentId String?   @map("owner_agent_id")
  // 'soft_deleted' | 'restored' | 'hard_deleted'
  phase        String
  // 'ttl_expired' | 'user_action' | 'cascade' | 'agent_revoked' |
  // 'retention_window_elapsed' | 'user_immediate' | ...
  reason       String
  at           DateTime  @default(now())

  // Two query patterns:
  //   - "what did this human delete, ordered by most recent" → (owner_human_id, at)
  //   - "find the audit row for this specific entity" → (entity_type, entity_id)
  @@index([ownerHumanId, at])
  @@index([entityType, entityId])
  @@map("deletion_log")
}
