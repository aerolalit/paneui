{
  "name": "@paneui/relay",
  "version": "0.0.6",
  "description": "Pane relay: HTTP + WebSocket server brokering UI surfaces between agents and humans.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:client": "tsc -p tsconfig.client.json",
    "prebuild:server": "node scripts/prisma-generate.mjs",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "predev": "npm run build:client && node scripts/prisma-generate.mjs",
    "dev": "tsx watch src/index.ts",
    "prestart": "node scripts/prisma-generate.mjs",
    "start": "node dist/index.js",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:postgres:deploy": "node scripts/migrate-deploy.mjs --schema prisma/postgres/schema.prisma",
    "studio": "prisma studio",
    "generate": "node scripts/prisma-generate.mjs",
    "generate:postgres": "node scripts/prisma-generate.mjs postgres",
    "check:schema-sync": "node scripts/check-schema-sync.mjs",
    "pretest": "npm run build:client && node scripts/prisma-generate.mjs sqlite",
    "test": "vitest run --exclude='**/*.multi-replica.test.ts' --exclude='**/node_modules/**'",
    "pretest:unit": "npm run build:client && node scripts/prisma-generate.mjs sqlite",
    "test:unit": "vitest run --exclude='**/*.e2e.test.ts' --exclude='**/*.integration.test.ts' --exclude='**/*.multi-replica.test.ts' --exclude='**/node_modules/**'",
    "pretest:e2e": "npm run build:client && node scripts/prisma-generate.mjs",
    "test:e2e": "vitest run .e2e.test.ts .integration.test.ts",
    "pretest:redis": "npm run build:client && node scripts/prisma-generate.mjs sqlite",
    "test:redis": "vitest run .multi-replica.test.ts",
    "test:watch": "vitest",
    "pretest:browser": "npm run build:client && prisma generate --schema prisma/schema.prisma",
    "test:browser": "playwright test",
    "pretypecheck": "npm run build:client",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/instrumentation-ioredis": "^0.66.0",
    "@opentelemetry/instrumentation-pg": "^0.70.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.41.0",
    "@paneui/core": "^0.0.6",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/instrumentation": "^7.8.0",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.10.0",
    "hono": "^4.6.0",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "sharp": "~0.34.5",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/monitor-opentelemetry-exporter": "^1.0.0-beta.32",
    "@azure/storage-attachment": "^12.31.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
