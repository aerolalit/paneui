{
  "name": "@pane/relay",
  "version": "0.0.1",
  "description": "Pane relay: HTTP + WebSocket server brokering UI sessions between agents and humans.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:client": "tsc -p tsconfig.client.json",
    "build:server": "tsc",
    "build": "npm run build:client && npm run build:server",
    "predev": "npm run build:client && node scripts/prisma-generate.mjs",
    "dev": "tsx watch src/index.ts",
    "prestart": "node scripts/prisma-generate.mjs",
    "start": "node dist/index.js",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:postgres:deploy": "prisma migrate deploy --schema prisma/schema.postgres.prisma",
    "studio": "prisma studio",
    "generate": "node scripts/prisma-generate.mjs",
    "generate:postgres": "node scripts/prisma-generate.mjs postgres",
    "pretest": "npm run build:client && node scripts/prisma-generate.mjs sqlite",
    "test": "vitest run",
    "pretest:unit": "npm run build:client && node scripts/prisma-generate.mjs sqlite",
    "test:unit": "vitest run --exclude='**/*.e2e.test.ts' --exclude='**/*.integration.test.ts' --exclude='**/node_modules/**'",
    "pretest:e2e": "npm run build:client && node scripts/prisma-generate.mjs",
    "test:e2e": "vitest run .e2e.test.ts .integration.test.ts",
    "test:watch": "vitest",
    "pretest:browser": "npm run build:client && prisma generate --schema prisma/schema.prisma",
    "test:browser": "playwright test",
    "pretypecheck": "npm run build:client",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@prisma/client": "^6.19.0",
    "ajv": "^8.20.0",
    "hono": "^4.6.0",
    "prisma": "^6.19.0",
    "ws": "^8.20.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.7.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
