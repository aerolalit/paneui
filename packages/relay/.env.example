# Pane v1 env vars. Copy to .env (gitignored) and edit. See docs/architecture/phase-1-skeleton-and-data.md for the full table.

# Database. SQLite for self-host (default), Postgres for the hosted build.
DATABASE_URL=file:./data/pane.db

# HTTP listen.
PORT=3000

# Base URL the relay is reachable at. MUST be set in any real deployment.
# PUBLIC_URL=https://pane.example.com

# Optional: bootstrap a default agent with this key on boot (idempotent).
# If unset and no agents exist, one is auto-minted and printed once.
# API_KEY=pane_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Encryption master key — used to encrypt secrets at rest (e.g. webhook
# callback secrets). MUST be 32 bytes, base64 or hex. Generate with:
#   openssl rand -base64 32
# If unset, the relay generates a key and persists it to a `.pane-secret-key`
# file next to the process — back that file up and keep it stable across
# restarts; losing it makes previously-encrypted data unrecoverable. Set this
# explicitly for any real deployment.
# PANE_SECRET_KEY=

# POST /v1/register is open (no secret). Abuse is bounded by a per-IP
# sliding-window rate limit. REGISTER_RATE_LIMIT=0 disables the limiter.
REGISTER_RATE_LIMIT=5
REGISTER_RATE_WINDOW_SECONDS=3600

# General per-IP + per-token rate limit applied to every /v1/* and /s/* route.
# RATE_LIMIT=0 disables it.
RATE_LIMIT=120
RATE_LIMIT_WINDOW_SECONDS=60

# Comma-separated proxy IPs the relay sits directly behind. X-Forwarded-For is
# only honored when the socket peer is one of these (the last untrusted hop is
# taken). Leave empty if the relay is exposed directly — a spoofed XFF header
# would otherwise let a client pick its own rate-limit bucket.
# TRUSTED_PROXY=10.0.0.1,10.0.0.2

# Abuse caps. 0 disables the corresponding cap.
MAX_WS_CONNECTIONS_PER_SESSION=16
MAX_SESSIONS_PER_AGENT=50
MAX_EVENTS_PER_SESSION=10000

# Size + TTL caps.
MAX_ARTIFACT_BYTES=2000000
MAX_EVENT_DATA_BYTES=65536
MAX_PARTICIPANTS_PER_SESSION=32
DEFAULT_TTL_SECONDS=3600
MAX_TTL_SECONDS=86400
TTL_SWEEP_SECONDS=60

LOG_LEVEL=info

# Optional Redis connection string — set this ONLY for a multi-replica
# deployment (e.g. an autoscaling Azure Container App). When set, the relay
# backs its cross-process state (event pub/sub, the rate limiter and the
# WebSocket presence registry) with Redis so every replica stays correct.
# When UNSET (the default), the relay uses in-process state — correct for a
# single replica and the right choice for self-host / local runs, which must
# not depend on a paid Redis service. The `ioredis` package is an
# optionalDependency, loaded only when this is set; a relay started with
# REDIS_URL but without `ioredis` installed fails fast with a clear message.
# REDIS_URL=redis://localhost:6379

# OpenTelemetry observability. The relay is instrumented once with the
# vendor-neutral OTel SDK; the exporter decides where telemetry goes.
# METRICS_ENABLED=false makes the instrument helpers no-ops and unmounts /metrics.
METRICS_ENABLED=true
# Exporter (default: none):
#   none       - no telemetry exported, GET /metrics not mounted (default).
#   prometheus - exposes GET /metrics in Prometheus text format on this same
#                port for self-host scraping.
#   azure      - pushes metrics, traces (HTTP + DB dependency spans),
#                exceptions and application logs to Azure Application
#                Insights; requires the optional
#                @azure/monitor-opentelemetry-exporter package and
#                APPLICATIONINSIGHTS_CONNECTION_STRING (below).
METRICS_EXPORTER=none
# Azure Application Insights connection string. Required ONLY when
# METRICS_EXPORTER=azure; ignored otherwise. Standard Azure Monitor env var.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
