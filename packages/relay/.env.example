# Pane v1 env vars. Copy to .env (gitignored) and edit. See docs/architecture/phase-1-skeleton-and-data.md for the full table.

# Database. SQLite for self-host (default), Postgres for the hosted build.
DATABASE_URL=file:./data/pane.db

# HTTP listen.
PORT=3000

# Base URL the relay is reachable at. MUST be set in any real deployment.
# PUBLIC_URL=https://pane.example.com

# Optional: bootstrap a default agent with this key on boot (idempotent).
# If unset and no agents exist, one is auto-minted and printed once.
# API_KEY=pane_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Encryption master key — used to encrypt secrets at rest (e.g. webhook
# callback secrets). MUST be 32 bytes, base64 or hex. Generate with:
#   openssl rand -base64 32
# If unset, the relay generates a key and persists it to a `.pane-secret-key`
# file next to the process — back that file up and keep it stable across
# restarts; losing it makes previously-encrypted data unrecoverable. Set this
# explicitly for any real deployment.
# PANE_SECRET_KEY=

# POST /v1/register is open (no secret). Abuse is bounded by a per-IP
# sliding-window rate limit. REGISTER_RATE_LIMIT=0 disables the limiter.
REGISTER_RATE_LIMIT=5
REGISTER_RATE_WINDOW_SECONDS=3600

# Size + TTL caps.
MAX_ARTIFACT_BYTES=2000000
MAX_EVENT_DATA_BYTES=65536
MAX_PARTICIPANTS_PER_SESSION=32
DEFAULT_TTL_SECONDS=3600
MAX_TTL_SECONDS=86400
TTL_SWEEP_SECONDS=60

LOG_LEVEL=info
