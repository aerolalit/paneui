{
  "name": "pane-cli",
  "version": "0.0.1",
  "description": "Command-line client for the Pane relay: create sessions, inspect state, send and watch events.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pane",
    "cli",
    "agent",
    "relay",
    "human-in-the-loop"
  ],
  "homepage": "https://github.com/aerolalit/pane#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aerolalit/pane.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/aerolalit/pane/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "pane": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@pane/core": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
