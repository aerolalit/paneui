{
  "name": "@paneui/cli",
  "version": "0.0.11",
  "description": "Command-line client for the Pane relay: create panes, inspect state, send and watch events.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pane",
    "cli",
    "agent",
    "relay",
    "human-in-the-loop"
  ],
  "homepage": "https://github.com/aerolalit/paneui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aerolalit/paneui.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/aerolalit/paneui/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "pane": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@paneui/core": "^0.0.11",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
