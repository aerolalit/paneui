{
  "name": "@paneui/core",
  "version": "0.0.2",
  "description": "Pane relay client: typed HTTP + WebSocket operations against a Pane relay. Framework-free.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pane",
    "agent",
    "websocket",
    "relay",
    "human-in-the-loop"
  ],
  "homepage": "https://github.com/aerolalit/paneui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aerolalit/paneui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/aerolalit/paneui/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "ws": "^8.20.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
