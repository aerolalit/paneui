{
  "name": "pane-example-telegram-bot-approval",
  "version": "0.0.0",
  "private": true,
  "description": "A Telegram bot that hands a human a pane URL for a rich decision and reads the structured result back over @paneui/core.",
  "type": "module",
  "engines": {
    "node": ">=20"
