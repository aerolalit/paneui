  "scripts": {
    "typecheck": "tsc --noEmit",
    "start": "node --experimental-strip-types src/bot.ts"
  },
  "dependencies": {
    "@paneui/core": "^0.0.18",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "typescript": "^5.6.0"
  }
}
